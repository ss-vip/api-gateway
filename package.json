{
  "name": "api-gateway",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "reset-db": "node -e \"require('fs').rmSync('.wrangler/state/v3/d1', {recursive:true, force:true})\"",
    "setup": "npx wrangler d1 execute DB --local --file=./schema.sql",
    "dev": "npx wrangler dev",
    "deploy": "npx wrangler d1 execute DB --remote --file=./schema.sql && npx wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.12.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "wrangler": "^4.87.0"
  }
}