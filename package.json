{
  "name": "api-gateway",
  "type": "module",
  "version": "2.0.0",
  "description": "AI API Gateway — Cloudflare Workers Edition",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate-local": "wrangler d1 execute api-gateway-db --local --file=./schema.sql",
    "db:migrate-remote": "wrangler d1 execute api-gateway-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.12.21"
  },
  "devDependencies": {
    "wrangler": "^4.93.0"
  }
}
