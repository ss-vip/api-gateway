{
  "_note": "複製為 config.json。所有值可由同名環境變數覆寫",
  "client_token": "optional-auth-bearer-token",

  "timezone": "Asia/Taipei",
  "port": 3000,
  "timeout": 600000,
  "key_cooldown": 30000,
  "max_key_backoff": 300000,
  "max_body_size": 10485760,

  "error_log": {
    "_note": "(選用) 啟用錯誤回應日誌，自動刪除超過 retention_days 的舊資料",
    "enabled": true,
    "retention_days": 7,
    "path": "./error.json"
  },

  "providers": {
    "_note": "只填入有 key 的 provider，未使用的可刪除或留空。支援清單與限制見 README",
    "openai": [""],
    "mistral": [""],
    "cerebras": [""],
    "deepseek": [""],
    "xai": [""],
    "groq": [""],
    "openrouter": [""],
    "together": [""],
    "perplexity": [""],
    "cohere": [""],
    "replicate": [""],
    "huggingface": [""],
    "baseten": [""],
    "parallel": [""],
    "pollinations": [""],
    "literouter": [""],
    "llm7": [""],
    "github-models": [""],
    "nvidia": [""],
    "gpt4free": [""],
    "agnes-ai": [""],
    "sea-lion": [""],
    "kilo": [""]
  },

  "tpm_limit": {
    "_note": "每 key 每分鐘 token 限制",
    "cerebras": 30000
  },

  "rate_limit": {
    "_note": "每個 key 請求間隔: 毫秒。不在此清單的 provider 會依 key 數量與 PROVIDER_RPM 自動計算",
    "cohere": 1000
  },

  "model_limits": {
    "_note": "每次請求 token 上限: provider/model → max context",
    "cerebras/gpt-oss-120b": 8192,
    "mistral/mistral-large": 32000,
    "nvidia/mistralai/mistral-small-4-119b-2603": 128000
  },

  "models": {
    "openai": [
      { "provider": "google-ai-studio", "model": "gemini-2.0-flash" },
      { "provider": "google-ai-studio", "model": "gemini-2.5-flash" },
      { "provider": "mistral", "model": "mistral-large-latest" },
      { "provider": "cerebras", "model": "llama3.1-70b" },
      { "provider": "deepseek", "model": "deepseek-chat" },
      { "provider": "openai", "model": "gpt-4o-mini" },
      { "provider": "pollinations", "model": "mistral-small-3.2" },
      { "provider": "literouter", "model": "owl-alpha:free:full-context" },
      { "provider": "llm7", "model": "fast" },
      { "provider": "github-models", "model": "openai/gpt-4o-mini" }
    ],

    "text-embedding-3-small": "openai",
    "text-embedding-3-large": "openai",
    "dall-e-3": "openai",
    "tts-1": "openai",
    "tts-1-hd": "openai",
    "whisper-1": "openai"
  }
}
