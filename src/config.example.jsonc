{
  // 複製為 config.jsonc。所有值可由同名環境變數覆寫。
  "account_id": "your-cloudflare-account-id",
  "gateway_name": "your-ai-gateway-name",
  "client_token": "optional-auth-bearer-token",

  "timezone": "Asia/Taipei",
  "port": 3000,
  "timeout": 600000,
  "key_cooldown": 30000,
  "max_key_backoff": 300000,
  "max_body_size": 10485760,

  /* (選用) 錯誤回應日誌，自動刪除超過 retention_days 的舊資料 */
  "error_log": {
    "enabled": true,
    "path": "./error.jsonc",
    "retention_days": 7
  },

  /* (選用) 啟用後訪問 /health 路由會從 GitHub 爬取公開免費 key 做備援 */
  "free_keys": {
    "enabled": true,
    "url": "https://raw.githubusercontent.com/alistaitsacle/free-llm-api-keys/refs/heads/main/README.md",
    "base_url": "https://aiapiv2.pekpik.com/v1",
    "interval_ms": 300000
  },

  /* (選用) 設 >0 天數，訪問 /health 時會調用 Cloudflare API 清理舊 log */
  "log_retention_days": 0,
  "cf_api_token": "your-cloudflare-api-token-with-ai-gateway-permission",

  "providers": {
    // 只填入有 key 的 provider，未使用的可刪除或留空
    "openai": [""],
    "anthropic": [""],
    "google-ai-studio": [""],
    "google-vertex-ai": [""],
    "azure-openai": [""],
    "aws-bedrock": [""],
    "mistral": [""],
    "cerebras": [""],
    "deepseek": [""],
    "xai": [""],
    "groq": [""],
    "openrouter": [""],
    "together": [""],
    "perplexity": [""],
    "cohere": [""],
    "replicate": [""],
    "huggingface": [""],
    "baseten": [""],
    "parallel": [""],
    "workers-ai": [""],
    "pollinations": [""],
    "literouter": [""],
    "llm7": [""]
  },

  "models": {
    "openai": [
      { "provider": "google-ai-studio", "model": "gemini-2.0-flash" },
      { "provider": "google-ai-studio", "model": "gemini-2.5-flash" },
      { "provider": "mistral", "model": "mistral-large-latest" },
      { "provider": "cerebras", "model": "llama3.1-70b" },
      { "provider": "deepseek", "model": "deepseek-chat" },
      { "provider": "openai", "model": "gpt-4o-mini" },
      { "provider": "pollinations", "model": "mistral-small-3.2" },
      { "provider": "literouter", "model": "owl-alpha:free:full-context" },
      { "provider": "llm7", "model": "fast" }
    ],

    "text-embedding-3-small": "openai",
    "text-embedding-3-large": "openai",
    "dall-e-3": "openai",
    "tts-1": "openai",
    "tts-1-hd": "openai",
    "whisper-1": "openai"
  }
}
